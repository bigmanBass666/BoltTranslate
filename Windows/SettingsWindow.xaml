<Window x:Class="BoltTranslate.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="450" Height="Auto"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="OnKeyDown"
        Deactivated="OnWindowDeactivated">
    <Border CornerRadius="8" Background="#FFFFFFFF" BorderBrush="#0D000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.15" Color="Black" Direction="270"/>
        </Border.Effect>
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20" Cursor="SizeAll" MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚙ 设置" FontSize="18" FontWeight="SemiBold" Foreground="#222222" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="配置文件" Background="Transparent" BorderBrush="#DDDDDD" BorderThickness="1" FontSize="12" Cursor="Hand" Padding="10,6" VerticalAlignment="Center" Click="OnOpenConfigFileClick">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBlock Text="快捷键" FontSize="12" Foreground="#666666" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Margin="0,0,0,4"/>
                <TextBox x:Name="HotkeyTextBox" IsReadOnly="True" Cursor="Hand" Padding="10,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" BorderBrush="#DDDDDD" BorderThickness="1" PreviewKeyDown="OnHotkeyPreviewKeyDown" PreviewKeyUp="OnHotkeyPreviewKeyUp" LostFocus="OnHotkeyLostFocus" GotFocus="OnHotkeyGotFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,14">
                <TextBlock Text="API Key" FontSize="12" Foreground="#666666" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Column="0" Padding="10,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" BorderBrush="#DDDDDD" BorderThickness="1" PasswordChanged="OnApiKeyPasswordChanged"/>
                    <TextBox x:Name="ApiKeyTextBox" Grid.Column="0" Visibility="Collapsed" Padding="10,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" BorderBrush="#DDDDDD" BorderThickness="1" TextChanged="OnApiKeyTextChanged"/>
                    <Button x:Name="ToggleApiKeyVisibilityButton" Grid.Column="1" Content="👁" Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="36" Height="34" VerticalAlignment="Bottom" Click="OnToggleApiVisibilityClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,4,4,0" BorderBrush="#DDDDDD" BorderThickness="0,1,1,1" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,14">
                <TextBlock Text="模型名称" FontSize="12" Foreground="#666666" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Margin="0,0,0,4"/>
                <TextBox x:Name="ModelTextBox" Padding="10,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" BorderBrush="#DDDDDD" BorderThickness="1"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,14">
                <TextBlock Text="代理地址（可选）" FontSize="12" Foreground="#666666" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Margin="0,0,0,4"/>
                <TextBox x:Name="ProxyUrlTextBox" Padding="10,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" BorderBrush="#DDDDDD" BorderThickness="1"/>
            </StackPanel>

            <CheckBox x:Name="AutoStartCheckBox" Grid.Row="5" Content="开机自启动" FontSize="13" Foreground="#333333" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="取消" Padding="18,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Background="Transparent" BorderBrush="#CCCCCC" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0" Click="OnCancelClick">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SaveButton" Content="保存" Padding="18,8" FontSize="13" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="OnSaveClick">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#006BB8"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>